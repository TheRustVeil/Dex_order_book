# Root-level secrets — never ship private keys into an image
/.env
/.env.local
/.env.*.local

# Dependencies — rebuilt inside the image
node_modules
**/node_modules

# Build artifacts — rebuilt inside the image
.next
**/.next
dist
**/dist
build
out

# Hardhat build outputs
packages/contracts/cache
packages/contracts/artifacts
packages/contracts/typechain-types
packages/contracts/gas-report.txt

# API runtime data (ephemeral JSON store)
packages/api/data

# Git and editor files
.git
*.log
dev-server.log
.DS_Store
Thumbs.db
