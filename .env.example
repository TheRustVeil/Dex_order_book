# ─── Wallet / Deployer ────────────────────────────────────────────────────────
# Private key of the deployer wallet (no 0x prefix)
PRIVATE_KEY=your_private_key_here

# ─── RPC Endpoints ───────────────────────────────────────────────────────────
# Get free endpoints from Alchemy (https://www.alchemy.com) or Infura

# Testnets
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
MUMBAI_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Mainnets (leave blank unless deploying to mainnet)
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BSC_RPC_URL=https://bsc-dataseed.binance.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ─── Block Explorer API Keys (for contract verification) ──────────────────────
ETHERSCAN_API_KEY=your_etherscan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key
BSCSCAN_API_KEY=your_bscscan_api_key
ARBISCAN_API_KEY=your_arbiscan_api_key

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Deployed contract addresses (filled in after testnet deploy)
NEXT_PUBLIC_ORDERBOOK_ADDRESS=
NEXT_PUBLIC_SETTLEMENT_ADDRESS=
NEXT_PUBLIC_TOKEN_REGISTRY_ADDRESS=
NEXT_PUBLIC_FACTORY_ADDRESS=

# ─── API Server ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://zetheta:zetheta@localhost:5432/dex
REDIS_URL=redis://localhost:6379

# ─── Monitoring ───────────────────────────────────────────────────────────────
REPORT_GAS=false   # set to "true" to enable gas reports on test runs

# ─── The Graph ───────────────────────────────────────────────────────────────
# Studio deploy key from https://thegraph.com/studio
GRAPH_DEPLOY_KEY=your_graph_deploy_key
GRAPH_SUBGRAPH_NAME=zetheta/dex-sepolia
